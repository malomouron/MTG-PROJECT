<UserControl x:Class="MtgClient.Views.DeckImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MtgClient.ViewModels">

    <Grid Background="#1a1a2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="20,16">
            <Button Content="← Retour" DockPanel.Dock="Left"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Height="32"/>
            <TextBlock Text="Importer un Deck" DockPanel.Dock="Left"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#e94560" Margin="20,0,0,0"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Foreground="#8899aa" FontSize="14" Margin="0,0,10,0">
                    <Run Text="{Binding CardCount, Mode=OneWay}"/>
                    <Run Text="/ 100 cartes"/>
                </TextBlock>
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14"
                           Foreground="{Binding IsValid, Converter={StaticResource BoolToSuccessColorConverter}}"/>
            </StackPanel>
        </DockPanel>

        <!-- Deck text input + validation -->
        <Grid Grid.Row="1" Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Text input -->
            <TextBox Grid.Column="0"
                     Text="{Binding DeckText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" AcceptsTab="False"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="13"
                     Background="#0f3460" Foreground="#e0e0e0"
                     BorderThickness="1" BorderBrush="#2a2a5a"
                     Padding="12"
                     TextWrapping="NoWrap"/>

            <!-- Validation panel -->
            <Border Grid.Column="1" Background="#16213e"
                    Margin="12,0,0,0" Padding="16"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock Text="Validation" DockPanel.Dock="Top"
                               FontSize="16" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,12"/>

                    <TextBlock DockPanel.Dock="Top" Foreground="#8899aa"
                               FontSize="12" Margin="0,0,0,8"
                               TextWrapping="Wrap">
Format attendu :
COMMANDER
1 Krenko, Mob Boss

DECK
1 Lightning Bolt
1 Sol Ring
35 Mountain
...
                    </TextBlock>

                    <ItemsControl DockPanel.Dock="Top"
                                  ItemsSource="{Binding ValidationErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#e94560"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom action bar -->
        <Border Grid.Row="2" Background="#16213e" Padding="20,12">
            <DockPanel>
                <Button Content="Confirmer et rejoindre" DockPanel.Dock="Right"
                        Command="{Binding ConfirmDeckCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Height="40" Width="220"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
