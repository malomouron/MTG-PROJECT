<UserControl x:Class="MtgClient.Views.GameEndView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MtgClient.ViewModels">

    <Grid Background="#1a1a2e">
        <Border Background="#16213e" CornerRadius="12" Padding="50"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="450">
            <StackPanel HorizontalAlignment="Center">
                <!-- Result icon -->
                <TextBlock Text="{Binding IsWin, Converter={StaticResource BoolToResultIconConverter}}"
                           FontSize="64" HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Result message -->
                <TextBlock Text="{Binding ResultMessage}"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{Binding IsWin, Converter={StaticResource BoolToResultColorConverter}}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Stats summary -->
                <Border Background="#0f3460" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.GamesPlayed}" FontSize="28"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Parties jouées" FontSize="11"
                                       Foreground="#8899aa" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.Wins}" FontSize="28"
                                       Foreground="#0fa3b1" HorizontalAlignment="Center"/>
                            <TextBlock Text="Victoires" FontSize="11"
                                       Foreground="#8899aa" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock FontSize="28" Foreground="#e94560"
                                       HorizontalAlignment="Center">
                                <Run Text="{Binding Stats.WinRate, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                <Run Text="%"/>
                            </TextBlock>
                            <TextBlock Text="Win rate" FontSize="11"
                                       Foreground="#8899aa" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Back button -->
                <Button Content="Retour au lobby"
                        Command="{Binding BackToLobbyCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Height="44" Width="220"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
