<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:MtgClient.Converters">

    <!-- ===== CONVERTERS ===== -->
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:BoolToConnectTextConverter x:Key="BoolToConnectTextConverter"/>
    <conv:BoolToSuccessColorConverter x:Key="BoolToSuccessColorConverter"/>
    <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
    <conv:TappedOpacityConverter x:Key="TappedOpacityConverter"/>
    <conv:EliminatedColorConverter x:Key="EliminatedColorConverter"/>
    <conv:BoolToConnectionColorConverter x:Key="BoolToConnectionColorConverter"/>
    <conv:BoolToResultIconConverter x:Key="BoolToResultIconConverter"/>
    <conv:BoolToResultColorConverter x:Key="BoolToResultColorConverter"/>
    <conv:SelectedCardBorderConverter x:Key="SelectedCardBorderConverter"/>
    <conv:WaitingToVisibilityConverter x:Key="WaitingToVisibilityConverter"/>

    <!-- ===== COLORS ===== -->
    <SolidColorBrush x:Key="BgPrimary" Color="#1a1a2e"/>
    <SolidColorBrush x:Key="BgPanel" Color="#16213e"/>
    <SolidColorBrush x:Key="BgInput" Color="#0f3460"/>
    <SolidColorBrush x:Key="AccentRed" Color="#e94560"/>
    <SolidColorBrush x:Key="AccentTeal" Color="#0fa3b1"/>
    <SolidColorBrush x:Key="TextMuted" Color="#8899aa"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#ffffff"/>

    <!-- ===== INPUT TEXT BOX ===== -->
    <Style x:Key="InputTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#0f3460"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="BorderBrush" Value="#2a2a4a"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#0fa3b1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== PRIMARY BUTTON ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="#e94560"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#d63851"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#c02a42"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#553344"/>
                            <Setter Property="Foreground" Value="#887788"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== SECONDARY BUTTON ===== -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#0fa3b1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="BorderBrush" Value="#0fa3b1"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#0f3460"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#16213e"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#445566"/>
                            <Setter Property="BorderBrush" Value="#2a3a4a"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== CARD STYLES ===== -->
    <Style x:Key="CardMini" TargetType="Border">
        <Setter Property="Background" Value="#0f3460"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Width" Value="70"/>
        <Setter Property="Height" Value="45"/>
    </Style>

    <Style x:Key="CardNormal" TargetType="Border">
        <Setter Property="Background" Value="#0f3460"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="MinHeight" Value="50"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="CardHand" TargetType="Border">
        <Setter Property="Background" Value="#1a2a4e"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#2a3a5a"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

</ResourceDictionary>
